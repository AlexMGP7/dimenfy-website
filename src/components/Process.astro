---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  {
    number: '01',
    title: t('process.1.title'),
    description: t('process.1.desc'),
  },
  {
    number: '02',
    title: t('process.2.title'),
    description: t('process.2.desc'),
  },
  {
    number: '03',
    title: t('process.3.title'),
    description: t('process.3.desc'),
  },
];
---

<section class="process section" id="proceso">
  <div class="container">
    <div class="reveal">
      <span class="section-label">{t('process.label')}</span>
      <h2 class="section-title">{t('process.title')}</h2>
      <p class="section-subtitle">
        {t('process.subtitle')}
      </p>
    </div>

    <div class="process-grid">
      {steps.map((step, index) => (
        <div class={`process-step reveal reveal-delay-${index + 1}`}>
          <div class="process-number">{step.number}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
